{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arabic Programming Lexicon",
  "type": "object",
  "required": ["core", "libraries", "messages"],
  "properties": {
    "core": {
      "type": "object",
      "required": ["meta", "dialect_entry"],
      "properties": {
        "meta": {
          "type": "object",
          "required": ["version", "default_dialect", "normalization"]
        },
        "dialect_entry": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dialect", "category", "python", "canonical", "alternates", "rationale"]
          }
        }
      }
    },
    "libraries": {
      "type": "object",
      "required": ["meta", "library"],
      "properties": {
        "meta": {
          "type": "object",
          "required": ["version"]
        },
        "library": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "python_module",
              "arabic_name",
              "alias_file",
              "group",
              "entries"
            ],
            "properties": {
              "python_module": { "type": "string" },
              "arabic_name": { "type": "string" },
              "alias_file": { "type": "string" },
              "group": { "type": "string" },
              "dict_version": { "type": "string" },
              "schema_version": { "type": "integer" },
              "maintainer": { "type": "string" },
              "optional_extra": { "type": "string" },
              "arabic_aliases": {
                "type": "array",
                "items": { "type": "string" }
              },
              "proxy_classes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "entries": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "attributes": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "messages": {
      "type": "object"
    }
  }
}
