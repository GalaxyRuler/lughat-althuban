{
  "name": "apython",
  "displayName": "لغة الثعبان (apython)",
  "description": "لهجة بايثون عربية: تلوين صياغي، تلميحات، تشخيصات، وإكمال لملفات .apy",
  "version": "0.1.0",
  "publisher": "apython-contributors",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "arabic",
    "python",
    "apython",
    "apy",
    "dialect"
  ],
  "activationEvents": [
    "onLanguage:apy"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "apy",
        "aliases": [
          "لغة الثعبان",
          "apython",
          "apy"
        ],
        "extensions": [
          ".apy"
        ],
        "configuration": "./language-config.json"
      }
    ],
    "grammars": [
      {
        "language": "apy",
        "scopeName": "source.apy",
        "path": "./syntaxes/apy.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "لغة الثعبان",
      "properties": {
        "apython.serverPath": {
          "type": "string",
          "default": "",
          "description": "مسار الأمر ثعبان. اتركه فارغا لاستخدام الأمر الموجود في PATH."
        },
        "apython.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "تتبع اتصال LSP بين VS Code وخادم لغة الثعبان."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  },
  "scripts": {
    "vscode:prepublish": "echo 'No build step required'",
    "package": "vsce package"
  }
}
