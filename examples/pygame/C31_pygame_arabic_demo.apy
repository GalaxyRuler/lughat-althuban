# مثال قصير: استعمال باي غيم بأسماء عربية

استورد لعبه


لعبه.ابدا()

النافذه = لعبه.نافذه((٣٢٠، ١٨٠))
لعبه.عنوان_النافذه("نافذة عربية")

خلفيه = (١٢، ١٨، ٣٠)
احمر = (٢٣٠، ٧٠، ٧٠)
ازرق = (٧٠، ١٤٠، ٢٣٠)

لاعب = لعبه.مستطيل(٤٠، ٧٠، ٣٢، ٣٢)
منصه = لعبه.مستطيل(٢٠، ١٣٠، ٢٨٠، ١٨)

لعبه.املا(النافذه، خلفيه)
لعبه.ارسم_مستطيل(النافذه، احمر، لاعب)
لعبه.ارسم_مستطيل(النافذه، ازرق، منصه)
لعبه.اعرض()

ساعه = لعبه.ساعه()
لعبه.انتظر_اطار(ساعه، ٦٠)
لعبه.اغلق()

اطبع("انتهى مثال باي غيم العربي")
