# C23_yaml_demo.apy — C-023 demo: YAML round-trip via Arabic aliases

استورد يامل


بيانات = {
    "اسم": "ليلى",
    "نشط": صحيح,
    "درجات": [95, 88, 91],
    "وسوم": {"لغة": "عربي", "صيغة": "YAML"},
}

نص_yaml = يامل.صدّر_آمن(بيانات, allow_unicode=صحيح, sort_keys=صحيح)
مستعاد = يامل.حمل_آمن(نص_yaml)

اكد مستعاد == بيانات
اطبع("YAML round-trip ok")
اطبع(نص_yaml)
