# C12_pydantic_demo.apy — C-012 demo: Pydantic models via Arabic aliases

استورد نماذج_بيانات


صنف مستخدم(نماذج_بيانات.نموذج_اساسي):
    اسم: str = نماذج_بيانات.حقل(min_length=2)
    عمر: نماذج_بيانات.عدد_غير_سالب
    نشط: bool = صحيح


مستخدم_واحد = مستخدم(اسم="ليلى", عمر=31)
بيانات = مستخدم_واحد.model_dump()

اكد بيانات["اسم"] == "ليلى"
اكد بيانات["عمر"] == 31
اكد بيانات["نشط"] == صحيح

اطبع("pydantic model ok")
اطبع(بيانات)
